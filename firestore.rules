rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin ekanligini admins/{uid} hujjati borligi orqali tekshiramiz
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Admin ro'yxati: har kim faqat o'z hujjatini o'qiy oladi.
    match /admins/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Vazifalar katalogi: o'qish — tizimga kirganlarga, yozish — faqat adminlarga.
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Yangiliklar: o'qish — tizimga kirganlarga, yozish — faqat adminlarga.
    match /news/{newsId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Promo kodlar: faqat admin boshqaradi; foydalanuvchi server (Cloud Function) orqali ishlatadi.
    match /promo_codes/{codeId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Foydalanuvchi profili — ANTI-CHEAT:
    // tanga maydonlarini (coins, lifetimeCoins, cashedOutTotal, dailyEarned...)
    // faqat server (Cloud Functions, Admin SDK) va admin o'zgartira oladi.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // Yangi hisob faqat nol balans bilan ochiladi
      allow create: if isOwner(uid)
        && request.resource.data.coins == 0
        && request.resource.data.lifetimeCoins == 0
        && request.resource.data.cashedOutTotal == 0
        && request.resource.data.dailyEarned == 0;

      // Egasi faqat kunlik hisoblagichlarni NOLGA tushira oladi (yangi kun boshlanishi),
      // boshqa hech qanday maydonga tegolmaydi
      allow update: if isAdmin() || (
        isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['taskCounts', 'dailyEarned', 'lastReset'])
        && request.resource.data.dailyEarned == 0
        && request.resource.data.taskCounts.size() == 0
      );

      allow delete: if isAdmin();

      // Tarix: yozish faqat server/admin orqali (mukofotlar serverda yoziladi)
      match /history/{entryId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // Pul yechish so'rovlari: yaratish FAQAT server (Cloud Function) orqali.
    match /cashout_requests/{reqId} {
      allow create: if false;
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
