rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin ekanligini admins/{uid} hujjati borligi orqali tekshiramiz
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Admin ro'yxati: har kim faqat o'z hujjatini o'qiy oladi (admin login tekshiruvi uchun).
    // Yozish faqat Firebase Console / Admin SDK orqali.
    match /admins/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Vazifalar katalogi: barcha tizimga kirgan foydalanuvchilar o'qiydi,
    // faqat adminlar qo'shadi/o'zgartiradi/o'chiradi.
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Foydalanuvchi profili: egasi yoki admin (ban qilish, tanga qaytarish uchun).
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();

      match /history/{entryId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // Pul yechish so'rovlari: foydalanuvchi faqat o'z nomidan yaratadi,
    // o'zinikini o'qiydi; tasdiqlash/rad etish faqat adminda.
    match /cashout_requests/{reqId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
